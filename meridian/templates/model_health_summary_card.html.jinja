<card class="model-health-card">
  <div class="health-score-section">
    <div class="score-container">
      <div class="score-label">Model health score</div>
      <div class="score-chart-and-value">
        <div class="health-score-chart" style="--score: {{ health_score }}">
        </div>
        <div class="score-value">{{ "%.1f"|format(health_score) }}</div>
      </div>
    </div>

    <div class="score-explanation">
      <div class="explanation-title">How is health score measured?</div>
      <p>
        The Meridian model health score gives a unified view of model integrity
        by combining six individual health checks into one metric ranging from 0
        to 100. While individual diagnostics provide granular insights into
        specific model components, the model health score provides an aggregate
        measure on a model's health for causal inference. See
        <a href="https://developers.google.com/meridian/docs/post-modeling/health-score" target="_blank">Model health score</a>
        to learn more.
      </p>
    </div>
  </div>

  {% if overall_status == 'FAIL' %}
  <div class="status-banner-strip fail">
     <span class="material-icons-outlined">error_outline</span>
     <span>{{ summary_message }}</span>
  </div>
  {% else %}
  <div class="status-banner-strip info">
     <span class="material-icons-outlined">check_circle</span>
     <span>{{ summary_message }}</span>
  </div>
  {% endif %}

  <div class="metrics-section">
    <div class="section-title">Metrics check</div>
    <table class="metrics-table">
      <thead>
        <tr>
          <th>Metric check</th>
          <th>Status</th>
          <th>Recommended action</th>
        </tr>
      </thead>
      <tbody>
        {% for check in metrics_checks %}
        <tr>
          <td>{{ check.name }}</td>
          <td><chip class="{{ check.status|lower }}">{{ check.status|title }}</chip></td>
          <td>{{ check.recommendation }}</td>
        </tr>
        {% endfor %}
        {% for check in advanced_checks %}
        <tr>
          <td>{{ check.name }}</td>
          <td>
            <div class="status-cell">
              {% if check.status == 'PASS' %}
                 <chip class="pass">Pass</chip>
              {% else %}
                 <chip class="review">Review</chip>
              {% endif %}
              <div class="stats-text">{{ check.passed_channels }}/{{ check.total_channels }} channels passed</div>
            </div>
          </td>
          <td>{{ check.recommendation }}</td>
        </tr>
        {% endfor %}
        {# copybara:strip_begin #}
        {% if has_calibration_recommendations %}
        <tr>
          <td>Calibration score</td>
          <td>
            <div class="status-cell">
              {% if n_recommended > 0 %}
                 <chip class="review">Review</chip>
              {% else %}
                 <chip class="pass">Pass</chip>
              {% endif %}
              <div class="stats-text">{{ n_recommended }}/{{ n_total_channels }} channels recommended</div>
            </div>
          </td>
          <td>
            The overall calibration score is {{ "%.1f"|format(calibration_score) }}/100.
            {% if recommended_channels_text %}
              We recommend incrementality experiments to improve prior accuracy for {{ recommended_channels_text }}.
            {% else %}
              No channels require calibration recommendations.
            {% endif %}
          </td>
        </tr>
        {% endif %}
        {# copybara:strip_end #}
      </tbody>
    </table>
  </div>

</card>